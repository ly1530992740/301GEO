# Qwen / 通义千问配置。产品画像、Prompt 生成、文章分析会调用 Qwen，会产生 API 成本。
DASHSCOPE_API_KEY=sk-your-qwen-key
DASHSCOPE_BASE_HTTP_API_URL=
QWEN_SEARCH_MODEL=qwen-plus
QWEN_ANALYSIS_MODEL=qwen3.7-max
QWEN_WRITING_MODEL=qwen-plus
QWEN_SEARCH_STRATEGY=max
QWEN_ANALYSIS_STRATEGY=agent_max
# Qwen 单次请求超时秒数。防止接口长期不返回导致页面一直转圈。
QWEN_TIMEOUT_SECONDS=120

# GEO 一键分析成本控制配置。
# GEO_AI_PROMPT_COUNT：每次生成几个真实用户问题。默认 5。每增加 1 个问题，会让 Qwen/豆包/元宝/DeepSeek 各多调用 1 次。
# GEO_AI_BRAND_DIAGNOSTIC_PROMPT_COUNT：品牌诊断问题数量。允许出现客户品牌，用来分析口碑/情绪，不参与主推荐排名。设为 0 可关闭。
# GEO_AI_COMPARISON_PROMPT_COUNT：竞品直接对比问题数量。会在中立推荐得出竞品后生成，不参与主推荐排名。设为 0 可关闭。
# GEO_AI_RECOMMENDATIONS_PER_PROMPT：每个问题让 AI 最多推荐几个品牌。默认 10。
# GEO_AI_VISIBILITY_BRAND_LIMIT：进入五平台声量估算的品牌数。默认 10，越大声量估算 prompt 越长。
# GEO_AI_SOURCE_LINK_LIMIT：最多保留多少个 AI 返回的引用/搜索链接。默认 80。
# GEO_AI_ARTICLE_FETCH_LIMIT：最多抓取多少个文章链接正文。默认 40，越大越慢，容易遇到反爬或连接失败。
# GEO_AI_ENABLE_PROMPT_DISCOVERY：是否调用 Qwen 生成 Prompt 组。true 会多一次 Qwen 调用；false 使用规则兜底问题。
GEO_AI_PROMPT_COUNT=5
GEO_AI_BRAND_DIAGNOSTIC_PROMPT_COUNT=3
GEO_AI_COMPARISON_PROMPT_COUNT=2
GEO_AI_RECOMMENDATIONS_PER_PROMPT=10
GEO_AI_VISIBILITY_BRAND_LIMIT=10
GEO_AI_SOURCE_LINK_LIMIT=80
GEO_AI_ARTICLE_FETCH_LIMIT=40
GEO_AI_ENABLE_PROMPT_DISCOVERY=true

SERPAPI_API_KEY=your-serpapi-key
SERPAPI_DEFAULT_GEO=CN
SERPAPI_DEFAULT_HL=zh-CN
SERPAPI_DEFAULT_GL=cn
SERPAPI_TIMEOUT_SECONDS=30

# 百度千帆 AI 搜索配置。当前主流程已主要改为多 AI 估算，后续改真实搜索声量时会重新启用。
BAIDU_API_KEY=your-baidu-qianfan-api-key
BAIDU_SEARCH_API_URL=https://qianfan.baidubce.com/v2/ai_search/web_search
BAIDU_SEARCH_EDITION=lite
BAIDU_SEARCH_SOURCE=baidu_search_v2
BAIDU_SEARCH_TOP_K=5
BAIDU_TIMEOUT_SECONDS=30

# 豆包配置。每个 Prompt 会调用一次，Prompt 数越多成本越高。
DOUBAO_API_KEY=your-doubao-ark-api-key
DOUBAO_RESPONSES_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses
DOUBAO_MODEL=doubao-seed-evolving
DOUBAO_TIMEOUT_SECONDS=90

# 元宝/腾讯混元配置。每个 Prompt 会调用一次，Prompt 数越多成本越高。
YUANBAO_API_KEY=your-tencent-hunyuan-api-key
YUANBAO_RESPONSES_API_URL=https://tokenhub.tencentmaas.com/v1/responses
YUANBAO_MODEL=hy3
YUANBAO_TIMEOUT_SECONDS=30

# DeepSeek 配置。每个 Prompt 会调用一次，Prompt 数越多成本越高。
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_CHAT_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30

# Future overseas AI providers. These are placeholders for later integration and are not called by the current workflow.
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=60

GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT_SECONDS=60

GROK_API_KEY=your-grok-api-key
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-4
GROK_TIMEOUT_SECONDS=60

# Future real keyword/search-volume providers. Current workflow still uses AI estimates.
KEYWORD_INTELLIGENCE_API_KEY=
KEYWORD_INTELLIGENCE_API_URL=
REAL_BAIDU_SEARCH_COUNT_API_URL=
REAL_SOGOU_SEARCH_COUNT_API_URL=
REAL_360_SEARCH_COUNT_API_URL=
REAL_DOUYIN_CONTENT_COUNT_API_URL=
REAL_XIAOHONGSHU_CONTENT_COUNT_API_URL=

# 5118 API。用于正式一键分析前置的真实用户关键词发现；缺 Key 或关闭开关时会自动退回 AI/规则问题生成。
# 5118 每个接口通常是独立 APIKEY；只填你购买过的接口即可。
ENABLE_5118_KEYWORD_INTELLIGENCE=true
API_5118_LONGTAIL_V2=
API_5118_SUGGEST=
API_5118_KW_PARAM_V2=
API_5118_RANK_PC=
API_5118_KWRANK_PC=
API_5118_TIMEOUT_SECONDS=30
KEYWORD_INTELLIGENCE_MAX_SEED_TERMS=9
KEYWORD_INTELLIGENCE_LONGTAIL_PAGE_SIZE=10
KEYWORD_INTELLIGENCE_ENABLE_SUGGEST=false
KEYWORD_INTELLIGENCE_REQUEST_INTERVAL_SECONDS=1.2

# 爱站 API。第一版仅用于独立连通测试和真实用户关键词数据模块，不进入正式一键分析流程。
AIZHAN_API_KEY=
AIZHAN_TIMEOUT_SECONDS=30

# 投媒 GEO。第一版仅用于独立连通测试和媒介发布渠道模块，不进入正式一键分析流程。
TOUMEI_GEO_BASE_URL=https://geo.toumeiw.cn
TOUMEI_GEO_SECRET_ID=
TOUMEI_GEO_SECRET_KEY=
TOUMEI_GEO_TIMEOUT_SECONDS=60

# 媒介库配置。真实媒介库同步会调用外部接口。
MEIJIEKU_BASE_URL=https://api.meijieku.com
MEIJIEKU_MOBILE=
MEIJIEKU_PASSWORD=
MEIJIEKU_TOKEN=
MEIJIEKU_RESOURCE_PAGE_SIZE=100
MEIJIEKU_RESOURCE_MAX_PAGES=20
MEIJIEKU_MOCK_MODE=false

MAX_PRICE_PER_PLATFORM=0
MAX_TOTAL_BUDGET=0
REQUIRE_FUZZY_CONFIRMATION=true
